<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.__USER__.claude-rc</string>

    <!--
      launchd starts agents with a bare environment (PATH=/usr/bin:/bin:...).
      Run through a login + interactive shell so .zprofile and .zshrc are
      sourced (brew, nvm, pnpm, .local/bin, etc.), then exec caffeinate so
      KeepAlive tracks the real process with no lingering shell. This is what
      gives the claude rc session — and every command it shells out to — the
      same PATH and env as your terminal.
    -->
    <key>ProgramArguments</key>
    <array>
        <string>__SHELL__</string>
        <string>-lic</string>
        <string>exec /usr/bin/caffeinate -i -m -s "__CLAUDE_BIN__" rc --remote-control-session-name-prefix rc-</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- unattended daemon: never block startup on an oh-my-zsh update prompt -->
        <key>DISABLE_AUTO_UPDATE</key>
        <string>true</string>
    </dict>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/claude-rc.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/claude-rc.err</string>

    <key>WorkingDirectory</key>
    <string>__WORKING_DIR__</string>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
